# window buttons
[org/gnome/desktop/wm/preferences]
button-layout='appmenu:minimize,maximize,close'

# accessibility
[org/gnome/desktop/a11y]
always-show-universal-access-status=true

# calendar
[org/gnome/desktop/calendar]
show-weekdate=true

# interface
[org/gnome/desktop/interface]
clock-show-weekday=true
enable-hot-corners=false
toolkit-accessibility=true

# login screen
[org/gnome/login-screen]
enable-fingerprint-authentication=false
enable-smartcard-authentication=false
enable-password-authentication=false
enable-auto-login=true

# control
[org/gnome/desktop/lockdown]
disable-command-line=true
# disable-lock-screen=true
disable-save-to-disk=true
disable-show-password=true
# disable-user-switching=true
# disable-log-out=true
user-administration-disabled=true

# notifications
[org/gnome/desktop/notifications]
show-banners=false
show-in-lock-screen=false

# numlock (initial state, can still be toggled normally)
[org/gnome/desktop/peripherals/keyboard]
numlock-state=true

# privacy
[org/gnome/desktop/privacy]
remember-app-usage=false
report-technical-problems=false
show-full-name-in-top-bar=false

# workspaces
[org/gnome/mutter]
dynamic-workspaces=false

# AFK
[org/gnome/desktop/screensaver]
idle-activation-enabled=false
lock-enabled=false
show-full-name-in-top-bar=false
status-message-enabled=false
# user-switch-enabled=false

# 0 disables the screen saver/blank screen completely (value is in seconds)
[org/gnome/desktop/session]
idle-delay=uint32 0

[org/gnome/settings-daemon/plugins/power]
sleep-inactive-ac-type='nothing'
sleep-inactive-battery-type='nothing'
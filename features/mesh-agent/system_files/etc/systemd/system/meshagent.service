[Unit]
Description=MeshCentral Agent
After=network-online.target
Wants=network-online.target
ConditionPathExists=/usr/libexec/meshagent/meshagent

[Service]
Type=simple
WorkingDirectory=/var/lib/meshagent
StateDirectory=meshagent
LogsDirectory=meshagent
RuntimeDirectory=meshagent
RuntimeDirectoryMode=0755
ExecStart=/usr/libexec/meshagent/meshagent
Restart=always
RestartSec=5
NoNewPrivileges=yes

[Install]
WantedBy=multi-user.target

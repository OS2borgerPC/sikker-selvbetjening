#!/bin/sh

# This script only resets user on logout.
# there is an extra script on boot for this, 
# incase of power loss or other unexpected shutdowns.
# located in create-guest.sh in the create-users feature.

# 1. Load global guest configuration
if [ -f /etc/guest-user.conf ]; then 
    . /etc/guest-user.conf 
else 
    GUEST_USER="Bruger" 
fi

# 2. Check if the logged-out user is our configured guest
if [ "$USER" = "$GUEST_USER" ]; then
    echo "[!] Active user session logout: Purging $GUEST_USER..."
    
    pkill -KILL -u "$GUEST_USER" || true
    sleep 1
    userdel -r "$GUEST_USER" || true
    rm -rf "/home/$GUEST_USER"

    # 3. Spawn a pristine profile for the next guest
    getent group nopasswdlogin >/dev/null || groupadd -r nopasswdlogin
    useradd -m -s /bin/bash -G "nopasswdlogin" "$GUEST_USER"
    passwd -d "$GUEST_USER"
fi

exit 0
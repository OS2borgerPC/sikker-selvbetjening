#!/bin/sh

TARGET_USER="Bruger"
PASSWORDLESS_GROUP="nopasswdlogin"

if [ "$USER" = "$TARGET_USER" ]; then

    # 1. Forcefully kill any lingering background processes
    pkill -KILL -u "$TARGET_USER" || true
    sleep 1

    # 2. Delete the user and completely wipe data
    userdel -r "$TARGET_USER" || true
    rm -rf "/home/$TARGET_USER"

    # 3. Ensure the passwordless group exists
    if ! getent group "$PASSWORDLESS_GROUP" >/dev/null; then
        groupadd -r "$PASSWORDLESS_GROUP"
    fi

    # 4. Recreate a fresh kiosk account assigned to the passwordless group
    useradd -m -s /bin/bash -G "$PASSWORDLESS_GROUP" "$TARGET_USER"
    passwd -d "$TARGET_USER"

fi

exit 0
#!/bin/bash
set -euo pipefail

# This script only resets user on logout.
# there is an extra script on boot for this, 
# incase of power loss or other unexpected shutdowns.
# located in create-guest.sh in the create-users feature.

TARGET_USER="Bruger"

echo "[!] Executing guest session reset for user: $TARGET_USER"

# Check if the user exists before trying to kill processes or delete files
if id "$TARGET_USER" >/dev/null 2>&1; then
    echo "[~] $TARGET_USER exists. Cleaning up active session..."
    
    # 1. Forcefully terminate any lingering processes belonging to the user
    pkill -KILL -u "$TARGET_USER" || true
    sleep 0.5

    # 2. Completely remove the user and their home directory
    userdel -r "$TARGET_USER" || true
    rm -rf "/home/$TARGET_USER"
else
    echo "[+] $TARGET_USER does not exist yet (First Boot). Skipping cleanup phase."
fi

# 3. Ensure the passwordless login group exists
getent group nopasswdlogin >/dev/null || groupadd -r nopasswdlogin

# 4. Create the user cleanly (works for both first-boot and recreation loops)
useradd -m -s /usr/sbin/nologin -p "" -G "nopasswdlogin" "$TARGET_USER"
passwd -d "$TARGET_USER"

echo "[+] $TARGET_USER has been successfully initialized to a pristine state."

systemctl restart gdm
exit 0
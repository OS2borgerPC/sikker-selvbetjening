{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./schema.json",
  "title": "Sikker Selvbetjening Combined Config",
  "description": "Single configuration schema that holds both policies and device_groups per domain.",
  "type": "object",
  "additionalProperties": false,
  "required": ["domains"],
  "properties": {
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/domain_entry"
      }
    }
  },
  "$defs": {
    "domain_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "policies", "device_groups"],
      "properties": {
        "domain": {
          "type": "string",
          "description": "Owning domain for the enclosed configuration.",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "minLength": 1
        },
        "policies": {
          "type": "array",
          "description": "List of configuration policies for this domain.",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/policy_entry"
          }
        },
        "device_groups": {
          "type": "array",
          "description": "List of device group definitions for this domain.",
          "items": {
            "$ref": "#/$defs/device_group_entry"
          }
        }
      }
    },
    "policy_entry": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique policy identifier. Used as the image name in the build pipeline.",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1
        },
        "desktop": {
          "title": "Desktop Section",
          "description": "Desktop configuration section.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "background_image_file": {
              "type": "string",
              "format": "data-url",
              "pattern": "^config/assets/[a-z][a-z0-9_-]*/.+",
              "description": "Asset path for the desktop background image. Values starting with config/assets/ are treated as file paths under config/assets."
            },
            "shortcuts_in_menu": {
              "type": "array",
              "description": "List of application shortcut IDs shown in the desktop menu.",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          }
        },
        "printer": {
          "title": "Printer Section",
          "description": "Printer configuration section.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "printers": {
              "type": "array",
              "description": "List of printers with printer-type-specific settings and one default printer.",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/printer_entry"
              },
              "contains": {
                "type": "object",
                "required": ["is_default"],
                "properties": {
                  "is_default": {
                    "const": true
                  }
                }
              },
              "minContains": 1,
              "maxContains": 1
            }
          }
        },
        "wifi": {
          "title": "Wi-Fi Section",
          "description": "Wi-Fi configuration section.",
          "type": "object",
          "additionalProperties": false,
          "required": ["ssid"],
          "properties": {
            "ssid": {
              "type": "string",
              "description": "SSID of the wireless network the client should connect to.",
              "minLength": 1
            },
            "psk": {
              "type": "string",
              "description": "Pre-shared key for the wireless network. This is sensitive data and should eventually be replaced by a runtime secret reference."
            },
            "hidden": {
              "type": "boolean",
              "description": "Whether the SSID is hidden and requires active probing by the client."
            }
          }
        },
        "favorite_apps": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apps": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          }
        },
        "firefox_urls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "urls": {
              "type": "array",
              "items": { "type": "string", "format": "uri" },
              "minItems": 1
            }
          }
        },
        "mesh_agent": {
          "title": "Mesh Agent",
          "description": "MeshCentral Mesh Agent configuration section.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "MeshCentral agent download URL."
            },
            "groupid": {
              "type": "string",
              "minLength": 1,
              "description": "MeshCentral group identifier to enroll the device in."
            }
          }
        }
      }
    },
    "device_group_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "policies", "image_name"],
      "properties": {
        "name": {
          "type": "string",
          "title": "Device Group Name",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "title": "Description",
          "description": "Optional description of the device group",
          "minLength": 1
        },
        "policies": {
          "type": "array",
          "title": "Policies",
          "minItems": 1,
          "items": {
            "type": "string",
            "title": "Policy Name",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "image_name": {
          "type": "string",
          "title": "Image Name",
          "description": "Identifier-safe image key for automation.",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        }
      }
    },
    "printer_entry": {
      "oneOf": [
        {
          "$ref": "#/$defs/printer_no_ppd_entry"
        },
        {
          "$ref": "#/$defs/printer_with_ppd_entry"
        },
        {
          "$ref": "#/$defs/printer_princh_entry"
        }
      ]
    },
    "printer_no_ppd_entry": {
      "type": "object",
      "description": "Printer entry that does not require a PPD file.",
      "additionalProperties": false,
      "required": ["printer-type", "name", "display_name", "ip", "is_default"],
      "properties": {
        "printer-type": {
          "const": "no_ppd"
        },
        "name": {
          "type": "string",
          "description": "Logical printer identifier.",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable printer name shown to users.",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Optional longer description of where the printer is located or how it is used.",
          "minLength": 1
        },
        "ip": {
          "type": "string",
          "description": "IPv4 address of the printer that the client should use.",
          "format": "ipv4"
        },
        "protocol": {
          "type": "string",
          "description": "Optional transport protocol used to reach the printer, for example ipp or socket.",
          "minLength": 1
        },
        "settings": {
          "$ref": "#/$defs/printer_settings"
        },
        "is_default": {
          "type": "boolean",
          "description": "Marks whether this printer is the default choice. Exactly one printer must be true per policy."
        }
      }
    },
    "printer_with_ppd_entry": {
      "type": "object",
      "description": "Printer entry that requires a PPD file.",
      "additionalProperties": false,
      "required": ["printer-type", "name", "display_name", "ip", "ppd_file", "is_default"],
      "properties": {
        "printer-type": {
          "const": "with_ppd"
        },
        "name": {
          "type": "string",
          "description": "Logical printer identifier.",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable printer name shown to users.",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Optional longer description of where the printer is located or how it is used.",
          "minLength": 1
        },
        "ip": {
          "type": "string",
          "description": "IPv4 address of the printer that the client should use.",
          "format": "ipv4"
        },
        "protocol": {
          "type": "string",
          "description": "Optional transport protocol used to reach the printer, for example ipp or socket.",
          "minLength": 1
        },
        "settings": {
          "$ref": "#/$defs/printer_settings"
        },
        "ppd_file": {
          "type": "string",
          "pattern": "^config/assets/[a-z][a-z0-9_-]*/.+",
          "description": "Asset path to a PPD file. Values starting with config/assets/ are treated as file paths under config/assets."
        },
        "is_default": {
          "type": "boolean",
          "description": "Marks whether this printer is the default choice. Exactly one printer must be true per policy."
        }
      }
    },
    "printer_princh_entry": {
      "type": "object",
      "description": "Princh printer entry.",
      "additionalProperties": false,
      "required": ["printer-type", "name", "display_name", "id", "is_default"],
      "properties": {
        "printer-type": {
          "const": "princh"
        },
        "name": {
          "type": "string",
          "description": "Logical printer identifier.",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable printer name shown in Princh-related UX.",
          "minLength": 1
        },
        "id": {
          "description": "Printer identifier provided by Princh.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "is_default": {
          "type": "boolean",
          "description": "Marks whether this printer is the default choice. Exactly one printer must be true per policy."
        }
      }
    },
    "printer_settings": {
      "type": "object",
      "description": "Optional default print settings for a printer profile.",
      "additionalProperties": false,
      "properties": {
        "page_size": {
          "type": "string",
          "description": "Default page size to use when printing, for example A4."
        },
        "color_mode": {
          "type": "string",
          "description": "Default color mode, for example rgb or grayscale."
        },
        "duplex": {
          "type": "string",
          "description": "Default duplex mode, for example none or duplex_tumble."
        },
        "orientation": {
          "type": "string",
          "description": "Default print orientation, for example portrait or landscape."
        }
      }
    }
  }
}

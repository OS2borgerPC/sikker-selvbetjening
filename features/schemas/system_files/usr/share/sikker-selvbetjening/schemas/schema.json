{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./schema.json",
  "title": "Sikker Selvbetjening Combined Config",
  "description": "Single configuration schema that holds both policies and device_groups per domain.",
  "type": "object",
  "additionalProperties": false,
  "required": ["domains"],
  "properties": {
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/domain_entry"
      }
    }
  },
  "$defs": {
    "asset_file_base": {
      "type": "string",
      "pattern": "^config/assets/[a-z][a-z0-9_-]*/.+",
      "description": "Asset path under config/assets/<domain>/...",
      "x-ssb-file": {
        "enabled": true,
        "assetPrefixTemplate": "config/assets/{domain}/",
        "downloadUrlTemplate": "https://raw.githubusercontent.com/{owner}/{repo}/{branch}/{path}"
      }
    },
    "asset_file_image": {
      "allOf": [
        {
          "$ref": "#/$defs/asset_file_base"
        }
      ],
      "description": "Asset path for an image file.",
      "x-ssb-file": {
        "enabled": true,
        "accept": "image/*",
        "assetPrefixTemplate": "config/assets/{domain}/",
        "downloadUrlTemplate": "https://raw.githubusercontent.com/{owner}/{repo}/{branch}/{path}"
      }
    },
    "asset_file_ppd": {
      "allOf": [
        {
          "$ref": "#/$defs/asset_file_base"
        }
      ],
      "description": "Asset path for a printer PPD file.",
      "x-ssb-file": {
        "enabled": true,
        "accept": ".ppd,text/plain,application/octet-stream",
        "assetPrefixTemplate": "config/assets/{domain}/",
        "downloadUrlTemplate": "https://raw.githubusercontent.com/{owner}/{repo}/{branch}/{path}"
      }
    },
    "domain_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "policies", "device_groups"],
      "properties": {
        "domain": {
          "type": "string",
          "description": "Owning domain for the enclosed configuration.",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "minLength": 1
        },
        "policies": {
          "type": "array",
          "description": "List of configuration policies for this domain.",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/policy_entry"
          }
        },
        "device_groups": {
          "type": "array",
          "description": "List of device group definitions for this domain.",
          "items": {
            "$ref": "#/$defs/device_group_entry"
          }
        }
      }
    },
    "policy_entry": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable policy identifier used for cross-references from device groups. In the plugin UI this is auto-generated when creating a new policy.",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "minLength": 1,
          "x-ssb-autogen": "policy-id"
        },
        "name": {
          "type": "string",
          "description": "Human-readable policy name. Used as the image name in the build pipeline.",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1
        },
        "desktop": {
          "title": "Desktop Section",
          "description": "Desktop configuration section.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "background_image_file": {
              "$ref": "#/$defs/asset_file_image",
              "description": "Asset path for the desktop background image. Values starting with config/assets/ are treated as file paths under config/assets."
            },
            "shortcuts_in_menu": {
              "type": "array",
              "description": "List of application shortcut IDs shown in the desktop menu.",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          }
        },
        "printer": {
          "title": "Printer Section",
          "description": "Printer configuration section.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "printers": {
              "type": "object",
              "description": "Typed printer collections. Add zero, one, or more printers under each printer type.",
              "additionalProperties": false,
              "properties": {
                "no_ppd": {
                  "type": "array",
                  "title": "No PPD Printers",
                  "description": "Printers that do not require a PPD file.",
                  "items": {
                    "$ref": "#/$defs/printer_no_ppd_entry"
                  }
                },
                "with_ppd": {
                  "type": "array",
                  "title": "With PPD Printers",
                  "description": "Printers that require a PPD file.",
                  "items": {
                    "$ref": "#/$defs/printer_with_ppd_entry"
                  }
                },
                "princh": {
                  "type": "array",
                  "title": "Princh Printers",
                  "description": "Princh printer configurations.",
                  "items": {
                    "$ref": "#/$defs/printer_princh_entry"
                  }
                }
              }
            }
          }
        },
        "wifi": {
          "title": "Wi-Fi Section",
          "description": "Wi-Fi configuration section.",
          "type": "object",
          "additionalProperties": false,
          "required": ["ssid"],
          "properties": {
            "ssid": {
              "type": "string",
              "description": "SSID of the wireless network the client should connect to.",
              "minLength": 1
            },
            "psk": {
              "type": "string",
              "description": "Pre-shared key for the wireless network. This is sensitive data and should eventually be replaced by a runtime secret reference."
            },
            "hidden": {
              "type": "boolean",
              "description": "Whether the SSID is hidden and requires active probing by the client."
            }
          }
        },
        "favorite_apps": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apps": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          }
        },
        "firefox_urls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "urls": {
              "type": "array",
              "items": { "type": "string", "format": "uri" },
              "minItems": 1
            }
          }
        },
        "mesh_agent": {
          "title": "Mesh Agent",
          "description": "MeshCentral Mesh Agent configuration section.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "MeshCentral agent download URL."
            },
            "groupid": {
              "type": "string",
              "minLength": 1,
              "description": "MeshCentral group identifier to enroll the device in."
            }
          }
        }
      }
    },
    "device_group_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "policies", "image_name"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Device group identifier used for cross-references. Can be a MeshCentral mesh id or any other identifier format.",
          "pattern": ".*\\S.*",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "title": "Device Group Name",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "title": "Description",
          "description": "Optional description of the device group",
          "minLength": 1
        },
        "policies": {
          "type": "array",
          "title": "Policies",
          "description": "List of policy IDs assigned to this device group.",
          "minItems": 1,
          "items": {
            "type": "string",
            "title": "Policy ID",
            "pattern": "^[a-z][a-z0-9_-]*$",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "image_name": {
          "type": "string",
          "title": "Image Name",
          "description": "Identifier-safe image key for automation.",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        }
      }
    },
    "printer_entry": {
      "oneOf": [
        {
          "title": "No PPD printer",
          "$ref": "#/$defs/printer_no_ppd_entry"
        },
        {
          "title": "With PPD printer",
          "$ref": "#/$defs/printer_with_ppd_entry"
        },
        {
          "title": "Princh printer",
          "$ref": "#/$defs/printer_princh_entry"
        }
      ]
    },
    "printer_no_ppd_entry": {
      "type": "object",
      "description": "Printer entry that does not require a PPD file.",
      "additionalProperties": false,
      "required": ["printer-type", "name", "display_name", "ip"],
      "properties": {
        "printer-type": {
          "const": "no_ppd"
        },
        "name": {
          "type": "string",
          "description": "Logical printer identifier.",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable printer name shown to users.",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Optional longer description of where the printer is located or how it is used.",
          "minLength": 1
        },
        "ip": {
          "type": "string",
          "description": "IPv4 address of the printer that the client should use.",
          "format": "ipv4"
        },
        "protocol": {
          "type": "string",
          "description": "Optional transport protocol used to reach the printer, for example ipp or socket.",
          "minLength": 1
        },
        "page_size": {
          "type": "string",
          "description": "Default page size to use when printing, for example A4."
        },
        "color_mode": {
          "type": "string",
          "description": "Default color mode, for example rgb or grayscale."
        },
        "duplex": {
          "type": "string",
          "description": "Default duplex mode, for example none or duplex_tumble."
        },
        "orientation": {
          "type": "string",
          "description": "Default print orientation, for example portrait or landscape."
        },
        "is_default": {
          "type": "boolean",
          "description": "Optional legacy flag. Currently not enforced by schema."
        }
      }
    },
    "printer_with_ppd_entry": {
      "type": "object",
      "description": "Printer entry that requires a PPD file.",
      "additionalProperties": false,
      "required": ["printer-type", "name", "display_name", "ip", "ppd_file"],
      "properties": {
        "printer-type": {
          "const": "with_ppd"
        },
        "name": {
          "type": "string",
          "description": "Logical printer identifier.",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable printer name shown to users.",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Optional longer description of where the printer is located or how it is used.",
          "minLength": 1
        },
        "ip": {
          "type": "string",
          "description": "IPv4 address of the printer that the client should use.",
          "format": "ipv4"
        },
        "protocol": {
          "type": "string",
          "description": "Optional transport protocol used to reach the printer, for example ipp or socket.",
          "minLength": 1
        },
        "page_size": {
          "type": "string",
          "description": "Default page size to use when printing, for example A4."
        },
        "color_mode": {
          "type": "string",
          "description": "Default color mode, for example rgb or grayscale."
        },
        "duplex": {
          "type": "string",
          "description": "Default duplex mode, for example none or duplex_tumble."
        },
        "orientation": {
          "type": "string",
          "description": "Default print orientation, for example portrait or landscape."
        },
        "ppd_file": {
          "$ref": "#/$defs/asset_file_ppd",
          "description": "Asset path to a PPD file. Values starting with config/assets/ are treated as file paths under config/assets."
        },
        "is_default": {
          "type": "boolean",
          "description": "Optional legacy flag. Currently not enforced by schema."
        }
      }
    },
    "printer_princh_entry": {
      "type": "object",
      "description": "Princh printer entry.",
      "additionalProperties": false,
      "required": ["printer-type", "name", "display_name", "id"],
      "properties": {
        "printer-type": {
          "const": "princh"
        },
        "name": {
          "type": "string",
          "description": "Logical printer identifier.",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable printer name shown in Princh-related UX.",
          "minLength": 1
        },
        "id": {
          "description": "Printer identifier provided by Princh.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "is_default": {
          "type": "boolean",
          "description": "Optional legacy flag. Currently not enforced by schema."
        }
      }
    }
  }
}

{
  "policies": {
    "desktop": {
      "background_image_file": {
        "ui:widget": "file",
        "ui:options": {
          "accept": "image/*",
          "assetPrefixTemplate": "config/assets/{domain}/"
        }
      }
    },
    "mesh_agent": {
      "agent_download_script_file": {
        "ui:widget": "file",
        "ui:options": {
          "accept": ".sh,text/x-shellscript,text/plain",
          "assetPrefixTemplate": "config/assets/{domain}/"
        }
      }
    }
  }
}
#!/bin/bash

# Define the variables
USERNAME="Bruger" 
# Use the absolute physical path to avoid symlink confusion during early boot
BRUGER_HOME="/var/home/$USERNAME"
TEMPLATE_DIR="/usr/template"

# 1. ANNIHILATE EXISTING USER
# Added || true to ensure the script NEVER exits with an error code. 
# If this script fails, the boot fails and the OS rolls back.
if id "$USERNAME" &>/dev/null; then
    userdel -r -f "$USERNAME" || true
fi

# 2. RECREATE USER FROM SCRATCH
# We use the system default but explicitly point to /var/home
useradd -m -d "$BRUGER_HOME" -s /bin/bash "$USERNAME" || true

# Clear the password
passwd -d "$USERNAME"

# 3. APPLY THE TEMPLATE
# Ensure the directory exists before wiping/copying
if [ -d "$BRUGER_HOME" ]; then
    find "$BRUGER_HOME" -mindepth 1 -delete
    cp -a "$TEMPLATE_DIR"/. "$BRUGER_HOME"/
fi

# 4. APPLY PERMISSIONS
chown -R "$USERNAME:$USERNAME" "$BRUGER_HOME"
chmod 755 "$BRUGER_HOME"

# 5. THE CRITICAL FIX: SELINUX
# This is likely why ostree-prepare-root is failing. 
# Newly created files in /var need to be labeled or the sysroot won't finalize.
restorecon -R "$BRUGER_HOME"

echo "User $USERNAME has been dynamically recreated and reset."
exit 0